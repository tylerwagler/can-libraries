/**
 * @file version.h
 * @brief Build-time version constants for libcan
 *
 * Generated by CMake from version.h.in — the @PROJECT_VERSION@ placeholders
 * resolve to the CanLibraries project() VERSION at configure time, so the
 * macros stay in sync with the on-disk SONAME and the installed package
 * version automatically.
 *
 * @copyright Copyright (c) 2026 Elytron Defense
 * @license GPL-3.0-or-later
 */

#ifndef CAN_VERSION_H
#define CAN_VERSION_H

#define LIBCAN_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define LIBCAN_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define LIBCAN_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define LIBCAN_VERSION_STRING "@PROJECT_VERSION@"

namespace can {

/// Returns the libcan version this header was compiled against — useful for
/// app "About" dialogs and diagnostic logs. Constexpr so it's compile-time
/// cheap.
constexpr const char* libraryVersion() { return LIBCAN_VERSION_STRING; }

} // namespace can

#endif // CAN_VERSION_H
