@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find required dependencies
find_package(PThreads4W QUIET)
if(NOT PThreads4W_FOUND)
    find_package(Threads REQUIRED)
endif()

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/CanLibrariesTargets.cmake")

# Check required components
check_required_components(CanLibraries)

# Provide imported targets
if(NOT TARGET CanLibraries::can)
    add_library(CanLibraries::can ALIAS CanLibraries::libcan)
endif()

if(NOT TARGET CanLibraries::dbc)
    add_library(CanLibraries::dbc ALIAS CanLibraries::libdbc)
endif()

# Set variables for backwards compatibility
set(CanLibraries_CAN_LIBRARIES CanLibraries::libcan)
set(CanLibraries_DBC_LIBRARIES CanLibraries::libdbc)
set(CanLibraries_LIBRARIES CanLibraries::libcan CanLibraries::libdbc)

# Include directory for backwards compatibility
set(CanLibraries_INCLUDE_DIRS "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
